<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
        The stdio MCP transport (StdioMcpServerConfig) reads/writes newline-delimited
        JSON-RPC on the process's own stdin/stdout. Any log line written to stdout would
        corrupt that stream, so logging goes to a file only - never to the console.
    -->
    <property name="LOG_FILE" value="${LOG_FILE:-logs/allotmint-mcp.log}"/>

    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>${LOG_FILE}</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="FILE"/>
    </root>
</configuration>
